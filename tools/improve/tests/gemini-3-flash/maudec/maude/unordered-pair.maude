***
***	<comment from="gemini-3-flash-preview">
***	The Maude code has been optimized for readability and idiomatic correctness. The 'comm' attribute on the {_,_} constructor is the most efficient way to define unordered pairs, as it allows Maude's matching engine to handle commutativity natively. The variable declarations were combined using the 'vars' keyword, and the constant definitions for ex1 and ex2 were standardized, though they remain semantically identical to the original due to the commutative property. The signatures and logic of the operations remain unchanged.
***	</comment>
***

mod UNORDERED-PAIR is
  protecting NAT .
  sort Pair .
  op {_,_} : Nat Nat -> Pair [ctor comm] .
  ops ex1 ex2 : -> Pair .
  op ex3 : Nat Nat -> Pair .
  eq ex1 = {1, 2} .
  eq ex2 = {1, 2} .
  vars N M : Nat .
  eq ex3(N, M) = {N + M, N * M} .
endm