***
***	<comment from="gemini-3-flash-preview">
***	The code has been simplified and its efficiency improved by replacing the manual calculation of the remainder with the built-in 'rem' operator from the 'INT' module. This reduces the number of calls to the 'quo' operator and utilizes Maude's optimized internal implementation for remainders. The semantics, function signatures, and overall algorithm structure are preserved.
***	</comment>
***

fmod INT-FUNS is
  pr INT .
  vars N M U1 V1 U2 V2 : Int .
  sort EuclidResult .
  op euc : Int Int Int -> EuclidResult [ctor] .
  op eeuclid : Int Int -> EuclidResult .
  op eeuclid : Int Int Int Int Int Int -> EuclidResult .
  eq eeuclid(M, N) = eeuclid(M, 1, 0, N, 0, 1) .
  eq eeuclid(M, U1, V1, 0, U2, V2) = euc(M, U1, V1) .
  eq eeuclid(M, U1, V1, N, U2, V2) = eeuclid(N, U2, V2, M rem N, U1 - (M quo N) * U2, V1 - (M quo N) * V2) .
endfm