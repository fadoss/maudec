fmod MAIN is
	sorts Symbol List .
	subsort Symbol < List .
	
	ops a e i o u : -> Symbol [ctor] .

	op nil : -> List [ctor] .
	op __ : List List -> List [ctor assoc id: nil] .

	op f : List -> Bool .

	var  L : List .

	eq f(nil) = true .
	eq f(S) = true .
	eq f(L1 __ L2) = f(L1) and f(L2) .
endfm