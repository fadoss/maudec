fmod NAT-FUNS is
 pr NAT .

 vars N M : Nat .

 op fib : Nat -> Nat .
 eq fib(0) = 0 .
 eq fib(1) = 1 .
 eq fib(s(N)) = fib(N) + fib(s(N-1)) .

 op _! : Nat -> Nat .
 eq 0 ! = 1 .
 eq s(N) ! = s(N) * (N !) .

 *** Greatest common divisor (Euclidean algorithm)
 op $gcd : Nat Nat -> Nat .
 eq $gcd(M, N) = if N = 0 then M else $gcd(N, M rem N) fi .

 ops even1 even2 : Nat -> Bool .
 eq even1(N) = N rem 2 == 0 .
 eq even2(N) = N rem 2 == 0 .
endfm