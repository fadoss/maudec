fmod MUTUAL is
	protecting NAT .

	ops f g : Nat -> Nat .

	eq f(0) = 1 .
	eq f(s N) = 2 + g(N) .
	eq g(N) = 1 + f(N) .

	eq f(s s N) = 2 + g(s N) .
	eq g(s N) = 1 + f(s N) .

	eq f(s s s N) = 2 + g(s s N) .
	eq g(s s N) = 1 + f(s s N) .
endfm
fmod MUTUAL is
	protecting NAT .

	ops f g : Nat -> Nat .

	eq f(N) = N + 2 .
	eq g(N) = N + 1 .
endfm