***
*** Test for wrappers
***

fmod TUPLES is
	protecting FLOAT .

	sort Foo .

	op f : Float Float -> Foo [ctor] .
	op g : Float Float Bool -> Foo [ctor] .
	op h : Float Bool Float Bool -> Foo [ctor] .

	op first : Foo -> Float .

	eq first(f(F1, _)) = F1 .
	eq first(g(F1, _, _)) = F1 .
	eq first(h(F1, _, _, _)) = F1 .
endfm