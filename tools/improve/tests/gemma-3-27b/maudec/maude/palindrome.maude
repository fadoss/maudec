fmod PALINDROME is
	sorts Symbol List . subsort Symbol < List .
	ops a e i o u : -> Symbol [ctor] .
	op nil : -> List [ctor] .
	op __ : List List -> List [ctor assoc id: nil] .
	op palindrome : List -> Bool .
	var L : List .

	eq palindrome(nil) = true .
	eq palindrome(S) = true .
	eq palindrome(L L) = palindrome(L) .
	eq palindrome(S1 __ S2 L) = palindrome(S1 S2 L) .
	eq palindrome(S1 __ L S2) = palindrome(S1 L S2) .
	eq palindrome(L __ S2 S3) = palindrome(L S2 S3) .
	eq palindrome(L __ L S3) = palindrome(L S3) .
	eq palindrome(S1 __ S2 S3) = palindrome(S2 S3) .
