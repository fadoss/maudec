mod NESTED-REWRITE-TEST is
	sort Foo Bar Ter .

	op f : Bar Foo [ctor] .
	op a : Bar [ctor] .
	op b : Bar [ctor] .
	op c : Bar [ctor] .
	op g : Bar -> Ter [ctor frozen (1)] .

	rl [ab] : a => b .
	rl [bc] : b => c .
endm