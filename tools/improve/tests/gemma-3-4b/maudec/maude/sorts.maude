fmod SORTS-TEST is
	protecting INT .

	sort Foo Bar .
	subsort Foo < Bar .

	op f : -> Foo [ctor] .
	op g : -> Bar [ctor] .

	var B : Bar .
	var F : Foo .

	op isFoo1 : Bar -> Bool .
	isFoo1(B) = B :: Foo .

	op isFoo2 : Bar -> Bool .
	isFoo2(F) = true .
	isFoo2(B) = false .

	op isPositive : Int -> Bool .
	isPositive(N:NzNat) = true .
	isPositive(Z:Int) = false .
endfm