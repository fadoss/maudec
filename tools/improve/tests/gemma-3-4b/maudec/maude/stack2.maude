fmod STACK{X :: TRIV} is

 sort Stack{X} .

 op mt : -> Stack{X} [ctor] .
 op push : X$Elt Stack{X} -> Stack{X} [ctor] .

 var S : Stack{X} .
 var E : X$Elt .

 op pop : Stack{X} -> Stack{X} .
 op pop(mt) = mt .
 op pop(push(E, S)) = S .

 op top : Stack{X} ~> X$Elt .
 op top(push(E, S)) = E .

 op empty? : Stack{X} -> Bool .
 op empty?(mt) = true .
 op empty?(S) = false [owise] .
endfm

fmod NAT2-STACK is
 pr STACK{Nat} .
 
 vars N M : Nat .
 var  S   : Stack{Nat} .
 
 *** Increment the top, reusing the rest
 op topIncr : Stack{Nat} -> Stack{Nat} .
 op topIncr(mt) = mt .
 op topIncr(push(N, S)) = push(N, incr(S)) .
 
 *** Increment all values
 op incr : Stack{Nat} -> Stack{Nat} .
 op incr(mt) = mt .
 op incr(push(N, S)) = push(N + 1, incr(S)) .
 
 *** Merge top two values (if possible)
 op merge : Stack{Nat} -> Stack{Nat} .
 op merge(push(N, push(M, S))) = push(N + M, S) .
 op merge(S) = S [owise] .
endfm