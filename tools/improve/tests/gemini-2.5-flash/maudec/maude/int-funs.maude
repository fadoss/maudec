***
***	<comment from="gemini-2.5-flash">
***	The code has been simplified by replacing the expression "M - (M quo N) * N" with the more concise and potentially more efficient "M rem N" operator. This preserves the semantics of the Extended Euclidean Algorithm while improving readability and relying on a potentially optimized native integer remainder operation.
***	</comment>
***

fmod INT-FUNS is
 pr INT .

 vars N M U1 V1 U2 V2 : Int .

 *** Extended Euclidean algorithm
 sort EuclidResult .
 op euc : Int Int Int -> EuclidResult [ctor] .

 op eeuclid : Int Int -> EuclidResult .
 op eeuclid : Int Int Int Int Int Int -> EuclidResult .

 eq eeuclid(M, N) = eeuclid(M, 1, 0, N, 0, 1) .
 eq eeuclid(M, U1, V1, 0, U2, V2) = euc(M, U1, V1) .
 eq eeuclid(M, U1, V1, N, U2, V2) = eeuclid(N, U2, V2, M rem N, U1 - (M quo N) * U2, V1 - (M quo N) * V2) .
endfm