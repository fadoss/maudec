***
***	<comment from="gemini-2.5-flash">
***	I've optimized the `normalize` operation by introducing a local variable `N` to store the result of `norm(< X, Y >)`. This avoids redundant calculations of the norm, making the code more efficient while preserving its original semantics.
***	</comment>
***

fmod REPEATED is
	protecting FLOAT .
	sort Vector .
	op <_,_> : Float Float -> Vector [ctor] .
	op norm : Vector -> Float .
	op normalize : Vector -> Vector .
	vars X Y : Float .
	eq norm(< X, Y >) = sqrt(X * X + Y * Y) .
	eq normalize(< X, Y >) =
		let N = norm(< X, Y >) in
			if N =/= 0.0 then
				< X / N, Y / N >
			else
				< X, Y >
			fi
		end .
endfm