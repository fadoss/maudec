***
***	<comment from="devstral-small-2">
***	The original Maude code defines a module TUPLES with three constructors (f, g, h) for the sort Foo, and a function first that extracts the first Float from any Foo value. The implementation is straightforward but can be made more efficient by using a single equation with a conditional to handle all cases, rather than separate equations for each constructor.
***	</comment>
***

fmod TUPLES is
	protecting FLOAT .

	sort Foo .

	op f : Float Float -> Foo [ctor] .
	op g : Float Float Bool -> Foo [ctor] .
	op h : Float Bool Float Bool -> Foo [ctor] .

	op first : Foo -> Float .

	vars F1 F2 : Float .
	vars B1 B2 : Bool .

	eq first(X:Foo) = cond X == f(F1, F2) => F1 ,
					 X == g(F1, F2, B1) => F1 ,
					 X == h(F1, B1, F2, B2) => F1 ,
					 true => F1 .

endfm