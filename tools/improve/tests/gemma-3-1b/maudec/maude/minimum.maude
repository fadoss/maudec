fmod MINIMUM is
  protecting NAT .

  op minimum : Nat Nat -> Nat [comm] .
  op minimum : Nat Nat -> Nat [comm] .

  vars M N : Nat .

  ceq minimum(M, N) = M if M <= N .
endfm