import scala.util.ExtendedPrimitive

object Eclidean {

  /**
   * Extended Eclidean algorithm.
   *
   * @param M The modulus.
   * @param N The number of digits.
   * @param U1 The first digit.
   * @param V1 The first digit.
   * @param U2 The second digit.
   * @param V2 The second digit.
   * @return The result of the Euclidean algorithm.
   */
  def euc(M: Int, N: Int, U1: Int, V1: Int, U2: Int, V2: Int): Int = {
    // Use ExtendedPrimitive for efficient integer arithmetic
    val result = extendedPrimitive.euc(M, N, U1, V1, U2, V2)
    result
  }

  // Extended primitive function for Eclidean algorithm
  def extendedPrimitive(M: Int, N: Int, U1: Int, V1: Int, U2: Int, V2: Int): Int =
    // This is a simplified implementation.  A more robust implementation
    // would handle potential overflow issues and edge cases more carefully.
    // This version is sufficient for demonstration purposes.
    val result =  (M * N) % (U1 * V1)
    result
}

// Example usage (for testing)
object Main {
  def main(args: Array[String]): Unit = {
    println(euc(3, 5, 1, 2, 3, 4))  // Example usage
  }
}